# ─── Database (Vercel Postgres) ────────────────────────────────────────────────
# Copia questi valori dal tuo progetto Vercel → Storage → Postgres → .env.local
POSTGRES_PRISMA_URL="postgres://user:password@host/db?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/db"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-char-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Twilio WhatsApp API ───────────────────────────────────────────────────────
# Dashboard: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"   # Twilio Sandbox number

# Meta (WhatsApp Business API) – alternativa a Twilio
# META_WHATSAPP_TOKEN="your_meta_api_token"
# META_PHONE_NUMBER_ID="your_phone_number_id"

# ─── Cron Job Security ─────────────────────────────────────────────────────────
# Segreto condiviso tra Vercel Cron e la route API
CRON_SECRET="replace-with-another-random-secret"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Beauty Backoffice"
NODE_ENV="development"
